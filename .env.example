GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Recommended free cloud TTS: Microsoft Edge Read Aloud voice, no local GPU/model.
TTS_PROVIDER=edge
EDGE_TTS_VOICE=id-ID-GadisNeural
EDGE_TTS_RATE=+8%
EDGE_TTS_PITCH=+18Hz
EDGE_TTS_VOLUME=+0%

# Use "stream" for better voice with lower delay, "server" for base64 fallback,
# or "browser" for the lowest latency with browser-dependent voice quality.
NEXT_PUBLIC_TTS_MODE=stream

# Optional server TTS providers:
# TTS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_INSTRUCTIONS=Speak in a soft, shy, cheerful Indonesian anime companion style.

# TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# TTS_PROVIDER=edge-local
EDGE_TTS_URL=http://127.0.0.1:5002

# Optional custom Live2D model URL.
NEXT_PUBLIC_LIVE2D_MODEL_URL=

# Optional default avatar size multiplier. Users can also fine-tune size/position in the app.
NEXT_PUBLIC_AVATAR_SCALE=1
