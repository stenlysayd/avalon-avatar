GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional. Leave "none" for browser speechSynthesis fallback on Vercel.
TTS_PROVIDER=none

# Optional server TTS providers:
# TTS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_INSTRUCTIONS=Speak in a soft, shy, cheerful Indonesian anime companion style.

# TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# TTS_PROVIDER=edge-local
EDGE_TTS_URL=http://127.0.0.1:5002

# Optional custom Live2D model URL.
NEXT_PUBLIC_LIVE2D_MODEL_URL=
